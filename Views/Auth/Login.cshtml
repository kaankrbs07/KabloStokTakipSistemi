@{
    Layout = null; 
}
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Giriş | KSTS</title>
  <style>
    :root { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; }
    body { margin: 0; background: #0b1220; color: #e6edf3; display: grid; place-items: center; min-height: 100vh; }
    .card { width: 100%; max-width: 420px; background: #0f192e; border: 1px solid #243557; border-radius: 14px; padding: 20px; box-shadow: 0 10px 25px rgba(0,0,0,.25); }
    .tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; background: #0b152a; padding: 6px; border-radius: 10px; margin-bottom: 16px; }
    .tab { padding: 10px 12px; border-radius: 8px; text-align: center; cursor: pointer; user-select: none; }
    .tab.active { background: #183158; }
    .field { display: grid; gap: 6px; margin: 10px 0 14px; }
    .field label { font-size: 13px; color: #b9c5d9; }
    .field input { padding: 10px 12px; border-radius: 9px; border: 1px solid #28406f; background: #0b152a; color: #e6edf3; }
    .row { display: flex; gap: 10px; }
    button { all: unset; display: inline-flex; align-items: center; justify-content: center; padding: 10px 14px; border-radius: 9px; cursor: pointer; background: #2b5bd7; color: white; font-weight: 600; }
    button.secondary { background: #32415f; }
    .muted { color: #9fb0cc; font-size: 13px; }
    .error { color: #ff9aa5; font-size: 14px; margin-top: 8px; min-height: 20px; }
    .ok { color: #8de7b9; font-size: 14px; margin-top: 8px; min-height: 20px; }
    .hidden { display: none; }
  </style>
</head>
<body>
  <div class="card">
    <div class="tabs">
      <div id="tab-admin" class="tab active">Admin</div>
      <div id="tab-employee" class="tab">Employee</div>
    </div>

    <!-- Admin Form -->
    <form id="form-admin">
      <div class="field">
        <label for="admin-username">Kullanıcı Adı</label>
        <input id="admin-username" name="username" autocomplete="username" required />
      </div>
      <div class="field">
        <label for="admin-password">Şifre</label>
        <input id="admin-password" name="password" type="password" autocomplete="current-password" required />
      </div>
      <div class="row">
        <button type="submit">Admin Giriş</button>
        <button id="logout-admin" type="button" class="secondary" title="Cookie temizle">Çıkış</button>
      </div>
      <div id="msg-admin" class="error"></div>
    </form>

    <!-- Employee Form -->
    <form id="form-employee" class="hidden">
      <div class="field">
        <label for="emp-id">Employee ID</label>
        <input id="emp-id" name="employeeId" inputmode="numeric" pattern="[0-9]*" required />
      </div>
      <div class="field">
        <label for="emp-pass">Şifre</label>
        <input id="emp-pass" name="password" type="password" autocomplete="current-password" required />
      </div>
      <div class="row">
        <button type="submit">Employee Giriş</button>
        <button id="logout-emp" type="button" class="secondary" title="Cookie temizle">Çıkış</button>
      </div>
      <div id="msg-emp" class="error"></div>
    </form>

    <p class="muted" style="margin-top:12px">Token stratejisi: Başarılı girişte JWT <strong>access_token</strong> cookie'sine yazılır. İstek atarken Authorization başlığı yoksa cookie'den okunup eklenir.</p>
  </div>

  <script>
    // ==========================
    // Cookie yardımcıları
    // ==========================
    function setCookie(name, value, opts={}) {
      const parts = [ `${name}=${encodeURIComponent(value)}` ];
      if (opts['max-age']) parts.push(`Max-Age=${opts['max-age']}`);
      if (opts.expires) parts.push(`Expires=${opts.expires.toUTCString()}`);
      parts.push(`Path=${opts.path || '/'}`);
      parts.push(`SameSite=${opts.samesite || 'Lax'}`);
      const isHttps = location.protocol === 'https:';
      if (opts.secure ?? isHttps) parts.push('Secure');
      document.cookie = parts.join('; ');
    }
    function getCookie(name) {
      return document.cookie.split('; ').find(x => x.startsWith(name+'='))?.split('=')[1] ?? null;
    }
    function deleteCookie(name) { setCookie(name, '', { 'max-age': 0 }); }

    // ==========================
    // JWT alma ve global fetch sarmalayıcı
    // ==========================
    window.__jwtCache = null; // header eklerken kullanacağız

    function getJwt() {
      if (window.__jwtCache) return window.__jwtCache;
      const c = getCookie('access_token');
      return c ? decodeURIComponent(c) : null;
    }

    // Authorization başlığını HER ZAMAN doldurmayı dene.
    // Eğer header yoksa cookie'den oku ve ekle -> Sunucu header bulamazsa zaten cookie fallback devreye girer.
    async function authFetch(url, options = {}) {
      const opts = { ...options };
      const headers = new Headers(opts.headers || {});
      if (!headers.has('Authorization')) {
        const jwt = getJwt();
        if (jwt) headers.set('Authorization', `Bearer ${jwt}`);
      }
      opts.headers = headers;
      // Gerekirse cookie de gitsin diye kredential'ı ekleyelim (CORS yoksa sorun olmaz)
      if (opts.credentials === undefined) opts.credentials = 'include';
      return fetch(url, opts);
    }

    // Sunucunun döndüğü olası şema varyasyonlarını destekle (token | accessToken | jwt)
    function readTokenFromResponse(obj) {
      return obj?.token || obj?.accessToken || obj?.jwt || obj?.Jwt || obj?.Token || null;
    }

    // Token'i cookie'ye yaz + hafızaya al
    function persistToken(token, expiresAt) {
      window.__jwtCache = token;
      let maxAge = 60 * 60 * 8; // 8 saat varsayılan
      if (expiresAt) {
        try {
          const exp = new Date(expiresAt);
          const sec = Math.max(1, Math.floor((exp.getTime() - Date.now()) / 1000));
          if (Number.isFinite(sec)) maxAge = sec;
        } catch {}
      }
      setCookie('access_token', token, { 'max-age': maxAge, samesite: 'Lax' });
    }

    // Basit yönlendirme kuralı
    function redirectByRole(role) {
      const r = (role || '').toLowerCase();
      if (r === 'admin') location.href = '/Admin/Dashboard';
      else if (r === 'employee') location.href = '/Employee/Dashboard';
      else location.href = '/';
    }

    // Sekmeler
    const tabAdmin = document.getElementById('tab-admin');
    const tabEmp   = document.getElementById('tab-employee');
    const formAdmin = document.getElementById('form-admin');
    const formEmp   = document.getElementById('form-employee');
    const msgAdmin = document.getElementById('msg-admin');
    const msgEmp   = document.getElementById('msg-emp');

    tabAdmin.addEventListener('click', () => {
      tabAdmin.classList.add('active');
      tabEmp.classList.remove('active');
      formAdmin.classList.remove('hidden');
      formEmp.classList.add('hidden');
      msgAdmin.textContent = '';
      msgEmp.textContent = '';
    });
    tabEmp.addEventListener('click', () => {
      tabEmp.classList.add('active');
      tabAdmin.classList.remove('active');
      formEmp.classList.remove('hidden');
      formAdmin.classList.add('hidden');
      msgAdmin.textContent = '';
      msgEmp.textContent = '';
    });

    // Admin login
    formAdmin.addEventListener('submit', async (e) => {
      e.preventDefault();
      msgAdmin.textContent = '';
      const username = document.getElementById('admin-username').value.trim();
      const password = document.getElementById('admin-password').value; // trim yok

      try {
        const res = await fetch('/api/auth/login/admin', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ username, password })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          msgAdmin.textContent = (data?.message || 'Giriş başarısız (401).');
          return;
        }
        const token = readTokenFromResponse(data);
        if (!token) { msgAdmin.textContent = 'Token alınamadı.'; return; }
        persistToken(token, data?.expiresAt || data?.exp || data?.expires);
        // Header test: Hemen korumalı bir endpointe call atalım (cookie -> header fallback test)
        const me = await authFetch('/api/auth/me');
        if (me.ok) {
          const meJson = await me.json().catch(() => ({}));
          redirectByRole(meJson?.role || data?.role);
        } else {
          // Sunucu header bulamazsa cookie'den okuyacak (Program.cs OnMessageReceived), yine de kullanıcıyı yönlendir.
          redirectByRole(data?.role);
        }
      } catch (err) {
        msgAdmin.textContent = 'Beklenmeyen hata: ' + (err?.message || err);
      }
    });

    // Employee login
    formEmp.addEventListener('submit', async (e) => {
      e.preventDefault();
      msgEmp.textContent = '';
      const employeeId = document.getElementById('emp-id').value.trim();
      const password = document.getElementById('emp-pass').value;

      try {
        const res = await fetch('/api/auth/login/employee', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ employeeId, password })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          msgEmp.textContent = (data?.message || 'Giriş başarısız (401).');
          return;
        }
        const token = readTokenFromResponse(data);
        if (!token) { msgEmp.textContent = 'Token alınamadı.'; return; }
        persistToken(token, data?.expiresAt || data?.exp || data?.expires);
        const me = await authFetch('/api/auth/me');
        if (me.ok) {
          const meJson = await me.json().catch(() => ({}));
          redirectByRole(meJson?.role || data?.role);
        } else {
          redirectByRole(data?.role);
        }
      } catch (err) {
        msgEmp.textContent = 'Beklenmeyen hata: ' + (err?.message || err);
      }
    });

    // Logout (cookie temizle)
    document.getElementById('logout-admin').addEventListener('click', () => {
      deleteCookie('access_token');
      window.__jwtCache = null;
      msgAdmin.className = 'ok';
      msgAdmin.textContent = 'Çıkış yapıldı (cookie temizlendi).';
    });
    document.getElementById('logout-emp').addEventListener('click', () => {
      deleteCookie('access_token');
      window.__jwtCache = null;
      msgEmp.className = 'ok';
      msgEmp.textContent = 'Çıkış yapıldı (cookie temizlendi).';
    });
  </script>
</body>
</html>
