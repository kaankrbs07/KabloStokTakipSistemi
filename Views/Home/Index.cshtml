@{
    Layout = null; // İstersen "_Layout" kullan
    ViewData["Title"] = "Ana Sayfa";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - Kablo Stok Takip Sistemi</title>
    <style>
        :root { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }
        body { margin:0; background:#0f172a; color:#e2e8f0; min-height:100vh; display:grid; place-items:center; }
        .wrap { width: min(720px, 92vw); padding:28px; text-align:center; }
        h1 { margin:0 0 8px; font-size:26px; }
        p.muted { color:#94a3b8; margin:0 0 18px; }
        .actions { display:flex; gap:12px; justify-content:center; margin-top:16px; flex-wrap:wrap; }
        a.btn { padding:12px 16px; border-radius:12px; text-decoration:none; font-weight:700; display:inline-block; }
        .primary { background:#2563eb; color:#fff; }
        .ghost   { background:#0b1220; color:#cbd5e1; border:1px solid #334155; }
        .bar { height:8px; width:100%; background:#0b1220; border-radius:12px; overflow:hidden; margin-top:16px; border:1px solid #334155; }
        .fill { height:100%; width:0%; background:#22c55e; transition:width .2s linear; }
        .hint { font-size:12px; color:#64748b; margin-top:10px; }
        code { font-family: ui-monospace, Menlo, Consolas, monospace; color:#cbd5e1; }
    </style>
</head>
<body>
<div class="wrap">
    <h1>Kablo Stok Takip Sistemi</h1>
    <p class="muted">Devam etmek için giriş yapın veya kayıt olun.</p>

    <div class="actions">
        <!-- Tag Helper kullanıyorsan: <a asp-controller="Auth" asp-action="Login" class="btn primary">Giriş Yap</a> -->
        <a href="/Auth/Login" class="btn primary">Giriş Yap</a>
        <a href="/Auth/SignUp" class="btn ghost">Kayıt Ol</a>
    </div>

    <div id="autoBox" style="margin-top:18px;">
        <div class="hint">
            <span id="msg">2 saniye içinde <code>/Auth/Login</code> sayfasına yönlendirileceksiniz…</span>
            <button id="cancel" style="margin-left:8px; background:transparent; border:1px solid #334155; color:#cbd5e1; padding:6px 10px; border-radius:8px; cursor:pointer;">
                İptal
            </button>
        </div>
        <div class="bar"><div id="fill" class="fill"></div></div>
    </div>

    <div class="hint">
        Doğrudan yönlendirme için query kullanabilirsiniz:
        <code>/?to=login</code> veya <code>/?to=signup</code>
    </div>
</div>

<script>
    // Yönlendirme hedefi: ?to=signup ise SignUp'a; aksi halde Login'e
    const params = new URLSearchParams(location.search);
    const target = (params.get("to") || "login").toLowerCase() === "signup" ? "/Auth/SignUp" : "/Auth/Login";

    // UI mesajını güncelle
    document.getElementById("msg").innerHTML = `2 saniye içinde <code>${target}</code> sayfasına yönlendirileceksiniz…`;

    // 2 saniyelik geri sayım + ilerleme çubuğu
    let elapsed = 0, total = 2000, step = 50;
    const fill = document.getElementById("fill");
    const timer = setInterval(() => {
        elapsed += step;
        fill.style.width = Math.min(100, Math.round((elapsed/total)*100)) + "%";
        if (elapsed >= total) {
            clearInterval(timer);
            window.location.href = target;
        }
    }, step);

    // İptal: otomatik yönlendirmeyi durdur
    document.getElementById("cancel").addEventListener("click", () => {
        clearInterval(timer);
        document.getElementById("autoBox").style.display = "none";
    });

    // (İsteğe bağlı) Eğer kullanıcı zaten oturum açtıysa otomatik yönlendirmeyi iptal etmek isteyebilirsiniz:
    // if (localStorage.getItem("token")) { clearInterval(timer); document.getElementById("autoBox").style.display = "none"; }
</script>
</body>
</html>
